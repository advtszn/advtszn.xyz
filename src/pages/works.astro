---
import Container from "~/components/common/container.astro";
import Layout from "~/layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import WorksList from "~/components/works/works-list";

const entries = (await getCollection("works")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const works = entries.map(({ id, data }) => ({ id, ...data }));

const descriptions = await Promise.all(
  entries.map(async (entry) => ({ id: entry.id, Content: (await render(entry)).Content })),
);
---

<Layout
  content={{
    title: "works | advtszn",
    description: "index of the works/projects i was involved in",
  }}
>
  <main>
    <Container>
      <div class="space-y-4">
        <div class="space-y-4 lg:max-w-[45%]">
          <h1 class="font-serif text-4xl italic md:text-6xl">works</h1>
          <p class="text-muted-foreground text-lg">
            the list includes all the startups, products and experiments i
            am/was affiliated with so far
          </p>
        </div>
        <WorksList works={works} client:load>
          {
            descriptions.map(({ id, Content }) => (
              <div data-work-id={id} hidden>
                <Content />
              </div>
            ))
          }
        </WorksList>
      </div>
    </Container>
  </main>
</Layout>
